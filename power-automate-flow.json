{
  "$schema": "https://schema.management.azure.com/schemas/2016-06-01/Microsoft.Logic.json",
  "contentVersion": "1.0.0.0",
  "parameters": {},
  "triggers": {
    "Recurrence": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "schedule": {
          "hours": ["8"],
          "minutes": [0]
        },
        "timeZone": "UTC"
      },
      "type": "Recurrence"
    }
  },
  "actions": {
    "Run_MITRE_Attack_Report": {
      "runAfter": {},
      "type": "ApiConnection",
      "inputs": {
        "host": {
          "connection": {
            "name": "@parameters('$connections')['securitycopilot']['connectionId']"
          }
        },
        "method": "post",
        "path": "/process-prompt",
        "body": {
          "prompt": "Run the MITREAttackReport skill and return the JSON results"
        }
      }
    },
    "Send_Results_to_Logic_App": {
      "runAfter": {
        "Run_MITRE_Attack_Report": ["Succeeded"]
      },
      "type": "Http",
      "inputs": {
        "method": "POST",
        "uri": "https://prod-25.northcentralus.logic.azure.com:443/workflows/6f4141e16b6c413d87085b991733528b/triggers/manual/paths/invoke?api-version=2019-05-01&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=1QVZ4btcsy5-Jw4AUC_EXdvNKx_r7JAvNOf4BTquP_I",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": "@outputs('Run_MITRE_Attack_Report')?['body']"
      }
    }
  }
}
