Descriptor:
  Name: ComplianceSecOpsReporting
  DisplayName: Compliance & SecOps Automated Reporting
  Description: |
    Comprehensive security reporting agent that provides automated compliance reporting
    mapped to NIST CSF 2.0, NIST 800-53, CIS Controls v8, and other frameworks.
    Integrates with Microsoft Security Copilot agents (Threat Intelligence Briefing,
    Phishing Triage) for enhanced threat context. All results are written to Sentinel
    watchlists for visualization in workbooks.
  Publisher: SecOps Team
  Version: 1.0.0
  Icon: ./assets/compliance-icon.svg

AgentConfiguration:
  Purpose: |
    This agent automates security reporting for compliance and security operations teams.
    It executes KQL queries mapped to specific compliance controls, enriches findings with
    threat intelligence from Security Copilot agents, and stores results in Sentinel watchlists
    for comprehensive dashboard visualization.

  EndGoal: |
    Provide SecOps teams with automated, compliance-mapped security reports that cover all
    critical security domains (Identity, Threats, Audit, Network, Vulnerabilities) with
    visual dashboards showing compliance posture, threat landscape, and remediation tracking.

  DeploymentScope: Workspace

  RequiredPlugins:
    - Microsoft Sentinel
    - Microsoft Threat Intelligence
    - Microsoft Entra ID
    - Microsoft Defender XDR

  OptionalIntegrations:
    - Threat Intelligence Briefing Agent
    - Phishing Triage Agent
    - Vulnerability Remediation Agent
    - Conditional Access Optimization Agent

SkillGroups:
  # ========================================================================
  # CONTROL LISTING AND MANAGEMENT SKILLS
  # ========================================================================
  - Format: GPT
    DisplayName: Control Management
    Description: List and manage compliance controls and report groups
    Skills:
      - Name: ListAllControls
        DisplayName: List All Compliance Controls
        Description: Lists all available compliance controls across all frameworks
        Settings:
          Template: |
            List all available compliance controls from the following frameworks:
            - NIST Cybersecurity Framework 2.0
            - NIST 800-53 Rev 5
            - CIS Controls v8

            For each control, provide:
            - Control ID
            - Framework
            - Description
            - Query Domain (identity, threat, audit, network, etc.)
            - Severity

            Use the compliance framework mapping configuration to generate this list.

      - Name: ListControlsByFramework
        DisplayName: List Controls by Framework
        Description: Lists all controls for a specific compliance framework
        Settings:
          Template: |
            List all compliance controls for the {{framework}} framework.

            Supported frameworks:
            - NIST_CSF_2.0 (NIST Cybersecurity Framework 2.0)
            - NIST_800_53 (NIST SP 800-53 Rev 5)
            - CIS_Controls_v8 (CIS Critical Security Controls v8)

            Provide control IDs, descriptions, query domains, and severities.

      - Name: ListReportGroups
        DisplayName: List Report Groups
        Description: Lists all pre-defined report groups and their controls
        Settings:
          Template: |
            List all available report groups including:
            - daily_critical: Daily Critical Security Monitoring
            - weekly_compliance: Weekly Compliance Review
            - identity_governance: Identity and Access Governance
            - threat_detection: Threat Detection and Response
            - audit_logging: Audit and Logging Review
            - vulnerability_management: Vulnerability and Patch Management

            For each group, show:
            - Name
            - Frequency
            - Included control IDs
            - Description

      - Name: ListControlsByDomain
        DisplayName: List Controls by Security Domain
        Description: Lists controls organized by security domain
        Settings:
          Template: |
            List all compliance controls organized by security domain:
            - Identity & Access Management
            - Threat Detection & Response
            - Data Protection
            - Audit & Logging
            - Network Security
            - Vulnerability Management
            - Asset Management
            - Incident Response

  # ========================================================================
  # IDENTITY & ACCESS MANAGEMENT QUERIES
  # ========================================================================
  - Format: KQL
    DisplayName: Identity & Access Reporting
    Description: Identity and access management compliance queries
    Skills:
      - Name: FailedAuthenticationReport
        DisplayName: Failed Authentication Attempts Report (AC-7, CIS-5.1)
        Description: Detect failed authentication attempts indicating brute force attacks
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            let timeRange = 24h;
            SigninLogs
            | where TimeGenerated > ago(timeRange)
            | where ResultType != 0
            | summarize
                FailedAttempts = count(),
                FirstAttempt = min(TimeGenerated),
                LastAttempt = max(TimeGenerated),
                Locations = make_set(Location),
                IPAddresses = make_set(IPAddress),
                Applications = make_set(AppDisplayName)
                by UserPrincipalName, UserDisplayName
            | where FailedAttempts >= 5
            | extend
                Severity = case(FailedAttempts >= 20, "Critical", FailedAttempts >= 10, "High", "Medium"),
                ControlID = "AC-7|CIS-5.1",
                Framework = "NIST 800-53|CIS Controls v8",
                QueryDomain = "identity",
                TimeGenerated = now(),
                FindingType = "Failed Authentication",
                RemediationRequired = iff(FailedAttempts >= 10, "Yes", "Review")

      - Name: PrivilegedAccountActivityReport
        DisplayName: Privileged Account Activity Report (AC-2, PR.AA-01)
        Description: Monitor privileged account usage for anomalous activity
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            let privilegedRoles = dynamic(["Global Administrator", "Privileged Role Administrator",
                "Security Administrator", "Application Administrator", "Cloud Application Administrator"]);
            AuditLogs
            | where TimeGenerated > ago(24h)
            | where Category == "RoleManagement" or ActivityDisplayName has_any ("role", "admin")
            | extend InitiatedByUser = tostring(InitiatedBy.user.userPrincipalName)
            | extend TargetUser = tostring(TargetResources[0].userPrincipalName)
            | extend RoleChanged = tostring(TargetResources[0].modifiedProperties[0].newValue)
            | where RoleChanged has_any (privilegedRoles)
            | project TimeGenerated, InitiatedByUser, TargetUser, ActivityDisplayName, RoleChanged, Result,
                Severity = "Critical", ControlID = "AC-2|PR.AA-01|CIS-6.1",
                Framework = "NIST 800-53|NIST CSF 2.0|CIS Controls v8",
                QueryDomain = "identity", FindingType = "Privileged Role Change", RemediationRequired = "Review"

      - Name: MFAComplianceReport
        DisplayName: MFA Compliance Status Report (IA-2, CIS-6.1)
        Description: Identify users without MFA enabled
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SigninLogs
            | where TimeGenerated > ago(7d)
            | summarize SignInCount = count(), MFAUsed = countif(AuthenticationRequirement == "multiFactorAuthentication"),
                LastSignIn = max(TimeGenerated) by UserPrincipalName, UserDisplayName
            | extend MFACompliance = iff(MFAUsed == SignInCount, "Compliant", "Non-Compliant")
            | where MFACompliance == "Non-Compliant"
            | project TimeGenerated = now(), UserPrincipalName, UserDisplayName, SignInCount, MFAUsed, LastSignIn,
                MFAComplianceRate = round((todouble(MFAUsed) / SignInCount) * 100, 2),
                Severity = "Critical", ControlID = "IA-2|CIS-6.1", Framework = "NIST 800-53|CIS Controls v8",
                QueryDomain = "identity", FindingType = "MFA Non-Compliance", RemediationRequired = "Yes"

      - Name: InactiveAccountsReport
        DisplayName: Inactive User Accounts Report (CIS-5.3, AC-2)
        Description: Identify inactive accounts that should be disabled
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            let inactivityThreshold = 90d;
            IdentityInfo
            | where TimeGenerated > ago(1d)
            | summarize arg_max(TimeGenerated, *) by AccountUPN
            | join kind=leftouter (SigninLogs | where TimeGenerated > ago(inactivityThreshold)
                | summarize LastSignIn = max(TimeGenerated) by UserPrincipalName)
                on $left.AccountUPN == $right.UserPrincipalName
            | where isnull(LastSignIn) or LastSignIn < ago(inactivityThreshold)
            | where AccountEnabled == true
            | project TimeGenerated = now(), UserPrincipalName = AccountUPN, AccountDisplayName, LastSignIn,
                DaysSinceLastSignIn = datetime_diff('day', now(), LastSignIn), AccountEnabled,
                Severity = "Medium", ControlID = "CIS-5.3|AC-2", Framework = "CIS Controls v8|NIST 800-53",
                QueryDomain = "identity", FindingType = "Inactive Account", RemediationRequired = "Yes"

  # ========================================================================
  # THREAT DETECTION & RESPONSE QUERIES
  # Integration with Threat Intelligence Briefing Agent
  # ========================================================================
  - Format: KQL
    DisplayName: Threat Detection & Response Reporting
    Description: Threat detection queries with agent enrichment
    Skills:
      - Name: CriticalAlertsReport
        DisplayName: High/Critical Security Alerts Report (SI-4, DE.AE-02)
        Description: Active high and critical severity security alerts (enriched with Threat Intel Agent)
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SecurityAlert
            | where TimeGenerated > ago(24h)
            | where AlertSeverity in ("High", "Critical")
            | extend Entities = parse_json(Entities), ExtendedProperties = parse_json(ExtendedProperties)
            | project TimeGenerated, AlertName, AlertSeverity, Description, RemediationSteps,
                CompromisedEntity, Tactics, Techniques, Entities, ProviderName, Status,
                Severity = "Critical", ControlID = "SI-4|DE.AE-02|CIS-13.1",
                Framework = "NIST 800-53|NIST CSF 2.0|CIS Controls v8",
                QueryDomain = "threat", FindingType = "Security Alert", RemediationRequired = "Yes",
                ThreatIntelEnrichment = "Eligible"

      - Name: MalwareDetectionsReport
        DisplayName: Malware Detections Report (SI-3, CIS-13.1)
        Description: Malware and malicious code detections
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SecurityAlert
            | where TimeGenerated > ago(24h)
            | where AlertName has_any ("malware", "virus", "trojan", "ransomware", "backdoor")
            | extend ThreatFamily = tostring(ExtendedProperties.["Threat Family"]),
                FilePath = tostring(ExtendedProperties.["File Path"]),
                FileName = tostring(ExtendedProperties.["File Name"])
            | project TimeGenerated, AlertName, AlertSeverity, CompromisedEntity, ThreatFamily,
                FilePath, FileName, RemediationSteps, Status, Severity = "Critical",
                ControlID = "SI-3|CIS-13.1", Framework = "NIST 800-53|CIS Controls v8",
                QueryDomain = "threat", FindingType = "Malware Detection", RemediationRequired = "Yes"

      - Name: PhishingAlertsReport
        DisplayName: Phishing and Email Threats Report (SI-4, DE.AE-02)
        Description: Phishing attempts and malicious email activity (triaged by Phishing Agent)
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SecurityAlert
            | where TimeGenerated > ago(24h)
            | where AlertName has_any ("phish", "email", "suspicious link", "malicious attachment")
            | extend SenderAddress = tostring(ExtendedProperties.["Sender Address"]),
                RecipientAddress = tostring(ExtendedProperties.["Recipient Address"]),
                Subject = tostring(ExtendedProperties.["Subject"]),
                UrlCount = tostring(ExtendedProperties.["Url Count"])
            | project TimeGenerated, AlertName, AlertSeverity, Description, SenderAddress,
                RecipientAddress, Subject, UrlCount, Status, Severity = "High",
                ControlID = "SI-4|DE.AE-02", Framework = "NIST 800-53|NIST CSF 2.0",
                QueryDomain = "threat", FindingType = "Phishing Attempt", RemediationRequired = "Yes",
                PhishingTriageEligible = "Yes"

      - Name: DataExfiltrationReport
        DisplayName: Data Exfiltration Indicators Report (DE.AE-02, RS.AN-01)
        Description: Potential data exfiltration activity
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SecurityAlert
            | where TimeGenerated > ago(24h)
            | where AlertName has_any ("exfiltration", "data transfer", "unusual data", "large file", "suspicious upload")
                or Tactics has "Exfiltration"
            | extend DataVolume = tostring(ExtendedProperties.["Data Volume"]),
                Destination = tostring(ExtendedProperties.["Destination"]),
                Protocol = tostring(ExtendedProperties.["Protocol"])
            | project TimeGenerated, AlertName, AlertSeverity, CompromisedEntity, Description,
                DataVolume, Destination, Protocol, Tactics, Techniques, Status, Severity = "Critical",
                ControlID = "DE.AE-02|RS.AN-01", Framework = "NIST CSF 2.0",
                QueryDomain = "threat", FindingType = "Data Exfiltration", RemediationRequired = "Yes",
                ThreatIntelEnrichment = "Eligible"

      - Name: MITREAttackReport
        DisplayName: MITRE ATT&CK Techniques Report (RS.AN-01, SI-4)
        Description: Map detected techniques to MITRE ATT&CK framework
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SecurityAlert
            | where TimeGenerated > ago(24h)
            | where isnotempty(Techniques)
            | extend TechniquesList = parse_json(Techniques)
            | mv-expand Technique = TechniquesList
            | summarize AlertCount = count(), AlertNames = make_set(AlertName),
                AffectedEntities = make_set(CompromisedEntity), FirstSeen = min(TimeGenerated),
                LastSeen = max(TimeGenerated), Severities = make_set(AlertSeverity)
                by tostring(Technique), Tactics
            | project TimeGenerated = now(), Technique, Tactics, AlertCount, FirstSeen, LastSeen,
                Severities, AffectedEntities,
                Severity = case(Severities has "Critical", "Critical", Severities has "High", "High", "Medium"),
                ControlID = "RS.AN-01|SI-4", Framework = "NIST CSF 2.0|NIST 800-53",
                QueryDomain = "threat", FindingType = "MITRE ATT&CK Activity", RemediationRequired = "Review"

      - Name: OpenIncidentsReport
        DisplayName: Open Security Incidents Report (RS.MA-01, RS.AN-01)
        Description: Track open security incidents requiring response
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            SecurityIncident
            | where TimeGenerated > ago(7d)
            | where Status in ("New", "Active")
            | extend IncidentAge = datetime_diff('hour', now(), CreatedTime),
                AssignedTo = tostring(Owner.assignedTo)
            | project TimeGenerated = now(), IncidentNumber, Title, Severity, Status, CreatedTime,
                LastModifiedTime, IncidentAge, AssignedTo, Classification, ClassificationReason,
                AlertsCount, Tactics = tostring(AdditionalData.tactics), ControlID = "RS.MA-01|RS.AN-01",
                Framework = "NIST CSF 2.0", QueryDomain = "threat", FindingType = "Open Incident",
                RemediationRequired = "Yes", SLA_Breached = iff(IncidentAge > 24, "Yes", "No")

  # ========================================================================
  # AUDIT & LOGGING QUERIES
  # ========================================================================
  - Format: KQL
    DisplayName: Audit & Logging Reporting
    Description: Audit trail and logging compliance queries
    Skills:
      - Name: AdminActivityReport
        DisplayName: Administrative Activity Report (AU-6, DE.CM-03)
        Description: Monitor administrative activities for unauthorized changes
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            AzureActivity
            | where TimeGenerated > ago(24h)
            | where OperationNameValue has_any ("Microsoft.Authorization", "Microsoft.Compute",
                "Microsoft.Network", "Microsoft.Storage")
            | where ActivityStatusValue == "Success"
            | extend InitiatedBy = tostring(Caller)
            | project TimeGenerated, OperationNameValue, ResourceProviderValue, ResourceGroup,
                SubscriptionId, InitiatedBy, ActivityStatusValue, Properties = parse_json(Properties),
                Severity = case(OperationNameValue has_any ("delete", "remove"), "Critical",
                    OperationNameValue has_any ("write", "create"), "High", "Medium"),
                ControlID = "AU-6|DE.CM-03|CIS-8.11", Framework = "NIST 800-53|NIST CSF 2.0|CIS Controls v8",
                QueryDomain = "audit", FindingType = "Administrative Activity", RemediationRequired = "Review"

      - Name: SecurityConfigChangesReport
        DisplayName: Security Configuration Changes Report (AU-2, CIS-8.2)
        Description: Track security configuration modifications
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            AuditLogs
            | where TimeGenerated > ago(24h)
            | where Category in ("Policy", "ApplicationManagement", "DirectoryManagement")
            | extend InitiatedByUser = tostring(InitiatedBy.user.userPrincipalName)
            | extend TargetResource = tostring(TargetResources[0].displayName)
            | extend ModifiedProperties = parse_json(TargetResources[0].modifiedProperties)
            | project TimeGenerated, ActivityDisplayName, Category, InitiatedByUser, TargetResource,
                ModifiedProperties, Result, OperationType, Severity = "Critical",
                ControlID = "AU-2|CIS-8.2", Framework = "NIST 800-53|CIS Controls v8",
                QueryDomain = "audit", FindingType = "Configuration Change", RemediationRequired = "Review"

      - Name: ResourceDeletionReport
        DisplayName: Resource Deletion Activities Report (AU-12, AU-6)
        Description: Track resource deletion for potential malicious activity
        Settings:
          Target: Sentinel
          TenantId: <TENANT_ID>
          SubscriptionId: <SUBSCRIPTION_ID>
          ResourceGroupName: <RESOURCE_GROUP>
          WorkspaceName: <WORKSPACE_NAME>
          Template: |-
            AzureActivity
            | where TimeGenerated > ago(24h)
            | where OperationNameValue endswith "delete" or OperationNameValue has "Delete"
            | where ActivityStatusValue == "Success"
            | project TimeGenerated, OperationNameValue, ResourceProviderValue, ResourceId,
                ResourceGroup, SubscriptionId, Caller, CallerIpAddress, Properties = parse_json(Properties),
                Severity = "Critical", ControlID = "AU-12|AU-6", Framework = "NIST 800-53",
                QueryDomain = "audit", FindingType = "Resource Deletion", RemediationRequired = "Review"

Triggers:
  - Name: DailyCriticalReportsTrigger
    Description: Execute daily critical security monitoring reports
    Schedule: "0 8 * * *"  # Daily at 8 AM
    FetchTool: null
    ProcessTool: RunDailyCriticalReports

  - Name: WeeklyComplianceReportsTrigger
    Description: Execute weekly compliance review reports
    Schedule: "0 9 * * 1"  # Weekly on Monday at 9 AM
    FetchTool: null
    ProcessTool: RunWeeklyComplianceReports

  - Name: ThreatIntelEnrichmentTrigger
    Description: Enrich threat findings with Threat Intelligence Briefing Agent
    Schedule: "0 */6 * * *"  # Every 6 hours
    FetchTool: FetchHighValueThreats
    ProcessTool: EnrichWithThreatIntel

# Additional metadata for workbook and watchlist integration
OutputConfiguration:
  Watchlists:
    - Name: ComplianceReports_Identity
      Schema:
        - TimeGenerated: datetime
        - ControlID: string
        - Framework: string
        - Severity: string
        - FindingType: string
        - UserPrincipalName: string
        - FindingDetails: dynamic
        - RemediationRequired: string

    - Name: ComplianceReports_Threats
      Schema:
        - TimeGenerated: datetime
        - ControlID: string
        - Framework: string
        - Severity: string
        - FindingType: string
        - AlertName: string
        - CompromisedEntity: string
        - Tactics: dynamic
        - Techniques: dynamic
        - ThreatIntelEnrichment: dynamic
        - RemediationRequired: string

    - Name: ComplianceReports_Audit
      Schema:
        - TimeGenerated: datetime
        - ControlID: string
        - Framework: string
        - Severity: string
        - FindingType: string
        - Operation: string
        - InitiatedBy: string
        - ResourceAffected: string
        - RemediationRequired: string

  WorkbookIntegration:
    Enabled: true
    AutoRefreshInterval: 900  # 15 minutes
    DataRetentionDays: 90
